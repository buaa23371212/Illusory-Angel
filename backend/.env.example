# 存储类型 (json/prisma)
# json: 使用JSON文件存储，无需数据库，适合本地开发和演示
# prisma: 使用Prisma ORM连接数据库，支持MySQL，适合生产环境
STORAGE_TYPE=json

# 数据库连接URL (仅当STORAGE_TYPE=prisma时需要)
# MySQL格式: mysql://user:password@host:port/dbname?schema=public
DATABASE_URL="mysql://root:password@localhost:3306/game_planner?schema=public"

# 服务器端口
PORT=3000

# 环境模式 (development/production)
NODE_ENV=development